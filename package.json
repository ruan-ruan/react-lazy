{
  "name": "react-lazy",
  "version": "1.0.0",
  "description": "React 18 图片懒加载组件和原生 JavaScript 懒加载实现",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
